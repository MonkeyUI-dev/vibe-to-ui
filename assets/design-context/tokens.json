{
  "$description": "Brand-shared Design Tokens for a vibe-to-ui Design Context profile. Format follows the W3C DTCG Design Tokens Format Module (2025.10) token envelope ($value / $type / $description / {aliases}), with group names aligned to Google DESIGN.md (colors, typography, spacing, rounded). Motion is a vibe-to-ui extension. Profile metadata lives under $extensions.",
  "$extensions": {
    "com.vibe-to-ui": {
      "profile": "<profile>",
      "displayName": "",
      "extractedFrom": [],
      "updatedAt": "YYYY-MM-DD",
      "confidence": "medium",
      "spec": {
        "dtcg": "2025.10",
        "designMd": "alpha"
      }
    }
  },

  "colors": {
    "$type": "color",
    "$description": "Semantic color roles. Values are CSS color strings (hex recommended), matching DESIGN.md. Prefer aliases for on-* / text roles when they reuse a palette token.",

    "primary": {
      "$value": "#______",
      "$description": "Primary brand / action color"
    },
    "secondary": {
      "$value": "#______",
      "$description": "Secondary brand color"
    },
    "tertiary": {
      "$value": "#______",
      "$description": "Optional accent / interaction highlight (DESIGN.md tertiary)"
    },
    "neutral": {
      "$value": "#______",
      "$description": "Foundation / page canvas when distinct from surface"
    },
    "background": {
      "$value": "#______",
      "$description": "Page / app background"
    },
    "surface": {
      "$value": "#______",
      "$description": "Raised content surface"
    },
    "surface-alt": {
      "$value": "#______",
      "$description": "Alternate surface / subtle grouping"
    },
    "on-surface": {
      "$value": "#______",
      "$description": "Primary text/icon on surface (DESIGN.md on-surface)"
    },
    "on-surface-muted": {
      "$value": "#______",
      "$description": "Secondary / supporting text on surface"
    },
    "on-primary": {
      "$value": "#______",
      "$description": "Text/icon on primary fills"
    },
    "border": {
      "$value": "#______",
      "$description": "Default border / divider"
    },
    "success": {
      "$value": "#______",
      "$description": "Success / positive status"
    },
    "warning": {
      "$value": "#______",
      "$description": "Warning status"
    },
    "error": {
      "$value": "#______",
      "$description": "Error / danger (DESIGN.md error)"
    },
    "info": {
      "$value": "#______",
      "$description": "Informational status"
    }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "$description": "Shared font stacks. Prefer arrays (most → least preferred) per DTCG fontFamily.",

    "heading": {
      "$value": ["[Heading Font]", "[fallback]", "sans-serif"]
    },
    "body": {
      "$value": ["[Body Font]", "[fallback]", "sans-serif"]
    },
    "mono": {
      "$value": ["[Mono Font]", "ui-monospace", "monospace"]
    }
  },

  "fontWeight": {
    "$type": "fontWeight",

    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },

  "typography": {
    "$type": "typography",
    "$description": "Composite text styles (DESIGN.md typography map). Names follow common DESIGN.md guidance: headline / body / label scales.",

    "headline-lg": {
      "$value": {
        "fontFamily": "{fontFamily.heading}",
        "fontSize": { "value": 40, "unit": "px" },
        "fontWeight": "{fontWeight.semibold}",
        "lineHeight": 1.15,
        "letterSpacing": { "value": -0.02, "unit": "rem" }
      }
    },
    "headline-md": {
      "$value": {
        "fontFamily": "{fontFamily.heading}",
        "fontSize": { "value": 28, "unit": "px" },
        "fontWeight": "{fontWeight.semibold}",
        "lineHeight": 1.2,
        "letterSpacing": { "value": -0.01, "unit": "rem" }
      }
    },
    "body-lg": {
      "$value": {
        "fontFamily": "{fontFamily.body}",
        "fontSize": { "value": 18, "unit": "px" },
        "fontWeight": "{fontWeight.regular}",
        "lineHeight": 1.6,
        "letterSpacing": { "value": 0, "unit": "rem" }
      }
    },
    "body-md": {
      "$value": {
        "fontFamily": "{fontFamily.body}",
        "fontSize": { "value": 16, "unit": "px" },
        "fontWeight": "{fontWeight.regular}",
        "lineHeight": 1.6,
        "letterSpacing": { "value": 0, "unit": "rem" }
      }
    },
    "body-sm": {
      "$value": {
        "fontFamily": "{fontFamily.body}",
        "fontSize": { "value": 14, "unit": "px" },
        "fontWeight": "{fontWeight.regular}",
        "lineHeight": 1.5,
        "letterSpacing": { "value": 0, "unit": "rem" }
      }
    },
    "label-md": {
      "$value": {
        "fontFamily": "{fontFamily.body}",
        "fontSize": { "value": 12, "unit": "px" },
        "fontWeight": "{fontWeight.medium}",
        "lineHeight": 1.2,
        "letterSpacing": { "value": 0.02, "unit": "rem" }
      }
    }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "Spacing scale (DESIGN.md spacing). Use for padding, gap, and margin rhythm.",

    "base": {
      "$value": { "value": 4, "unit": "px" },
      "$description": "Base unit / half-step reference"
    },
    "xs": { "$value": { "value": 4, "unit": "px" } },
    "sm": { "$value": { "value": 8, "unit": "px" } },
    "md": { "$value": { "value": 16, "unit": "px" } },
    "lg": { "$value": { "value": 24, "unit": "px" } },
    "xl": { "$value": { "value": 32, "unit": "px" } },
    "2xl": { "$value": { "value": 48, "unit": "px" } }
  },

  "rounded": {
    "$type": "dimension",
    "$description": "Corner radius scale (DESIGN.md rounded — not 'radius').",

    "none": { "$value": { "value": 0, "unit": "px" } },
    "sm": { "$value": { "value": 4, "unit": "px" } },
    "md": { "$value": { "value": 8, "unit": "px" } },
    "lg": { "$value": { "value": 16, "unit": "px" } },
    "full": {
      "$value": { "value": 9999, "unit": "px" },
      "$description": "Pill / fully rounded"
    }
  },

  "elevation": {
    "$description": "Depth system. Prefer DTCG shadow composites; record strategy in $extensions when depth is tonal/border-led instead of shadow-led.",
    "$extensions": {
      "com.vibe-to-ui": {
        "strategy": "shadow-led",
        "notes": "Use tonal / border / blur strategies when shadows are absent; keep shadow tokens empty or minimal."
      }
    },

    "sm": {
      "$type": "shadow",
      "$value": {
        "color": {
          "colorSpace": "srgb",
          "components": [0, 0, 0],
          "alpha": 0.06,
          "hex": "#000000"
        },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 1, "unit": "px" },
        "blur": { "value": 2, "unit": "px" },
        "spread": { "value": 0, "unit": "px" }
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "color": {
          "colorSpace": "srgb",
          "components": [0, 0, 0],
          "alpha": 0.08,
          "hex": "#000000"
        },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 4, "unit": "px" },
        "blur": { "value": 6, "unit": "px" },
        "spread": { "value": 0, "unit": "px" }
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "color": {
          "colorSpace": "srgb",
          "components": [0, 0, 0],
          "alpha": 0.1,
          "hex": "#000000"
        },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 10, "unit": "px" },
        "blur": { "value": 15, "unit": "px" },
        "spread": { "value": 0, "unit": "px" }
      }
    }
  },

  "motion": {
    "$description": "Motion tokens (vibe-to-ui extension; not yet in DESIGN.md alpha). Uses DTCG duration, cubicBezier, and transition composites.",
    "$extensions": {
      "com.vibe-to-ui": {
        "tempo": "medium",
        "density": "moderate",
        "reducedMotion": "fade-only"
      }
    },

    "duration": {
      "$type": "duration",
      "instant": { "$value": { "value": 0, "unit": "ms" } },
      "fast": { "$value": { "value": 150, "unit": "ms" } },
      "normal": { "$value": { "value": 250, "unit": "ms" } },
      "slow": { "$value": { "value": 400, "unit": "ms" } },
      "slower": { "$value": { "value": 600, "unit": "ms" } }
    },

    "easing": {
      "$type": "cubicBezier",
      "default": { "$value": [0.2, 0.8, 0.2, 1] },
      "in": { "$value": [0.4, 0, 1, 1] },
      "out": { "$value": [0, 0, 0.2, 1] },
      "elastic": { "$value": [0.34, 1.56, 0.64, 1] }
    },

    "distance": {
      "$type": "dimension",
      "$description": "Typical translate distances for entrances / micro-interactions.",
      "sm": { "$value": { "value": 4, "unit": "px" } },
      "md": { "$value": { "value": 12, "unit": "px" } },
      "lg": { "$value": { "value": 24, "unit": "px" } }
    },

    "transition": {
      "$type": "transition",
      "$description": "Named transitions composed from duration + easing.",
      "fast": {
        "$value": {
          "duration": "{motion.duration.fast}",
          "delay": { "value": 0, "unit": "ms" },
          "timingFunction": "{motion.easing.default}"
        }
      },
      "normal": {
        "$value": {
          "duration": "{motion.duration.normal}",
          "delay": { "value": 0, "unit": "ms" },
          "timingFunction": "{motion.easing.default}"
        }
      },
      "slow": {
        "$value": {
          "duration": "{motion.duration.slow}",
          "delay": { "value": 0, "unit": "ms" },
          "timingFunction": "{motion.easing.out}"
        }
      }
    }
  }
}
